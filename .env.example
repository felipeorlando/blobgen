# ─────────────────────────────────────────────────────────────────────────────
# blobgen environment — copy to `.env.local` and fill in.
# The app BOOTS with zero config (defaults below match docker-compose); you only
# need keys to actually run the AI stages. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required; default matches docker-compose) ──────────────────────
DATABASE_URL="postgres://blobgen:blobgen@localhost:5432/blobgen"

# ── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate one with: openssl rand -base64 32   (optional in dev)
AUTH_SECRET=""
# Dev-only password-less login (no OAuth setup needed). Defaults true in dev.
AUTH_DEV_LOGIN="true"
# Google OAuth (covers YouTube connect). Create at https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── LLM — OpenRouter (https://openrouter.ai/keys) ────────────────────────────
OPENROUTER_API_KEY=""
# Any OpenRouter model id — see https://openrouter.ai/models. Override freely.
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# ── Web research — Tavily (default) or Exa ───────────────────────────────────
SEARCH_PROVIDER="tavily"          # tavily | exa
TAVILY_API_KEY=""                 # https://tavily.com
EXA_API_KEY=""                    # https://exa.ai (only if SEARCH_PROVIDER=exa)

# ── YouTube Data API v3 (public data; https://console.cloud.google.com) ──────
YOUTUBE_API_KEY=""

# ── Replicate (Wave 2: image/video/voice; https://replicate.com/account) ─────
REPLICATE_API_TOKEN=""

# ── Stock material banks (Wave 1 Materials stage; optional) ──────────────────
PEXELS_API_KEY=""                 # https://www.pexels.com/api/

# ── Background jobs ──────────────────────────────────────────────────────────
# inprocess = single process, zero infra (great for local dev/verification)
# bullmq    = durable Redis-backed queue; needs Redis + a `bun run worker` process
JOB_DRIVER="inprocess"            # inprocess | bullmq
REDIS_URL="redis://localhost:6379"

# ── Blob storage ─────────────────────────────────────────────────────────────
STORAGE_DRIVER="fs"               # fs | s3 (s3 = future wave)
STORAGE_DIR="./.storage"

# ── Credits ──────────────────────────────────────────────────────────────────
STARTING_CREDITS="500"
