# ── Model credential (pick one) ─────────────────────────────────────────────
# Direct Anthropic key, or a Vercel AI Gateway token.
ANTHROPIC_API_KEY=
# AI_GATEWAY_API_KEY=

# ── OpenMontage (the creative engine) ───────────────────────────────────────
# Clone https://github.com/calesthio/OpenMontage and run `make setup`, then:
OPENMONTAGE_DIR=
PYTHON_BIN=python3

# ── blobgen bridge (the productization shell) ───────────────────────────────
# Where to report progress (mirrored into blobgen stage_runs) + the shared HMAC
# secret. Must match blobgen's EVE_CALLBACK_SECRET.
BLOBGEN_URL=http://localhost:3000
BLOBGEN_CALLBACK_SECRET=dev-shared-secret

# Leave paid-provider keys blank to stay on OpenMontage's zero-key path
# (Piper TTS, FFmpeg, Remotion, Archive.org/Pexels). OpenMontage reads its own
# .env for provider keys; configure them there.
